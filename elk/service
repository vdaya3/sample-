⸻

✅ 1️⃣ Proper Production systemd Service for Filebeat

Create or override:

sudo systemctl edit --full filebeat

Replace with:

[Unit]
Description=Filebeat Log Shipper
Documentation=https://www.elastic.co/beats/filebeat
After=network.target

[Service]
Type=simple
User=root
Group=root

ExecStart=/usr/share/filebeat/bin/filebeat \
  --environment systemd \
  -c /etc/filebeat/filebeat.yml

Restart=always
RestartSec=5
StartLimitBurst=5
StartLimitIntervalSec=60

LimitNOFILE=65536
TimeoutStopSec=30

StandardOutput=append:/var/log/filebeat/filebeat-service.log
StandardError=append:/var/log/filebeat/filebeat-service-error.log

[Install]
WantedBy=multi-user.target


